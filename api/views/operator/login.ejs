<%# PAYWIFI-OPERATOR-OTP-2026-06-03 — modern mobile sign-in + register + verify %>
<style>
  /* ── Mobile-first layout shell ─────────────────────────────────────── */
  .auth-shell {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    padding-top: env(safe-area-inset-top, 0);
    padding-bottom: env(safe-area-inset-bottom, 0);
    padding-left:  env(safe-area-inset-left, 0);
    padding-right: env(safe-area-inset-right, 0);
    background: var(--background);
  }
  .auth-hero {
    padding: 40px 24px 32px;
    text-align: center;
    background: linear-gradient(180deg,
      color-mix(in oklab, var(--primary) 12%, var(--background)) 0%,
      var(--background) 100%);
  }
  .auth-brand-mark {
    width: 64px; height: 64px;
    border-radius: 20px;
    background: var(--primary);
    color: var(--primary-foreground);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 28px;
    letter-spacing: -0.02em;
    margin-bottom: 18px;
    box-shadow: 0 12px 40px -12px color-mix(in oklab, var(--primary) 60%, transparent),
                0 2px 0 0 color-mix(in oklab, var(--primary) 20%, transparent) inset;
  }
  .auth-title {
    font-size: 28px;
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: var(--foreground);
    margin: 0 0 6px;
  }
  .auth-subtitle {
    font-size: 15px;
    line-height: 1.5;
    color: var(--muted-foreground);
    margin: 0 auto;
    max-width: 320px;
  }
  .auth-card {
    flex: 1;
    padding: 8px 20px 32px;
    max-width: 480px;
    width: 100%;
    margin: 0 auto;
  }

  /* ── Segmented control tabs ────────────────────────────────────────── */
  .seg {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4px;
    padding: 4px;
    background: color-mix(in oklab, var(--muted-foreground) 12%, var(--card));
    border-radius: 14px;
    margin-bottom: 20px;
  }
  .seg-btn {
    background: transparent;
    border: 0;
    padding: 11px 14px;
    border-radius: 10px;
    font-weight: 600;
    font-size: 14px;
    color: var(--muted-foreground);
    cursor: pointer;
    transition: all 200ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .seg-btn[aria-pressed="true"] {
    background: var(--background);
    color: var(--foreground);
    box-shadow: 0 1px 3px color-mix(in oklab, #000 10%, transparent),
                0 1px 2px color-mix(in oklab, #000 6%, transparent);
  }

  /* ── Form fields ──────────────────────────────────────────────────── */
  .field {
    position: relative;
    margin-bottom: 14px;
  }
  .field-label {
    display: block;
    font-size: 12px;
    font-weight: 600;
    color: var(--muted-foreground);
    margin-bottom: 6px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .field-input {
    width: 100%;
    box-sizing: border-box;
    height: 56px;
    padding: 0 18px;
    border-radius: 14px;
    border: 1.5px solid var(--border);
    background: var(--background);
    color: var(--foreground);
    font-size: 17px;
    font-weight: 500;
    transition: border-color 150ms ease, box-shadow 150ms ease;
    appearance: none;
    -webkit-appearance: none;
  }
  .field-input:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 4px color-mix(in oklab, var(--primary) 12%, transparent);
  }
  .field-input::placeholder { color: color-mix(in oklab, var(--muted-foreground) 70%, transparent); font-weight: 400; }
  .field-prefix {
    position: absolute;
    left: 18px;
    top: 50%;
    transform: translateY(calc(-50% + 9px));
    color: var(--muted-foreground);
    font-size: 17px;
    font-weight: 500;
    pointer-events: none;
    user-select: none;
  }
  .field-input.with-prefix { padding-left: 56px; }
  .field-hint {
    margin: 6px 4px 0;
    font-size: 12px;
    color: var(--muted-foreground);
    line-height: 1.4;
  }

  /* ── OTP code boxes ───────────────────────────────────────────────── */
  .otp-row {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 8px;
    margin: 16px 0 6px;
  }
  @media (max-width: 360px) {
    .otp-row { gap: 6px; }
  }
  .otp-cell {
    height: 60px;
    text-align: center;
    font-size: 24px;
    font-weight: 700;
    border-radius: 12px;
    border: 1.5px solid var(--border);
    background: var(--background);
    color: var(--foreground);
    appearance: none;
    -webkit-appearance: none;
    font-variant-numeric: tabular-nums;
    transition: all 150ms ease;
  }
  .otp-cell:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 4px color-mix(in oklab, var(--primary) 12%, transparent);
    transform: translateY(-1px);
  }
  .otp-cell:not(:placeholder-shown) {
    border-color: color-mix(in oklab, var(--primary) 35%, var(--border));
    background: color-mix(in oklab, var(--primary) 4%, var(--background));
  }
  .otp-row.shake { animation: otp-shake 320ms cubic-bezier(0.36, 0.07, 0.19, 0.97) both; }
  @keyframes otp-shake {
    0%, 100% { transform: translateX(0); }
    20%, 60% { transform: translateX(-6px); }
    40%, 80% { transform: translateX(6px); }
  }

  /* ── Primary button ───────────────────────────────────────────────── */
  .btn-primary {
    width: 100%;
    height: 56px;
    border-radius: 14px;
    border: 0;
    background: var(--primary);
    color: var(--primary-foreground);
    font-size: 16px;
    font-weight: 700;
    letter-spacing: -0.01em;
    cursor: pointer;
    transition: transform 100ms ease, opacity 150ms ease, box-shadow 200ms ease;
    box-shadow: 0 8px 24px -8px color-mix(in oklab, var(--primary) 60%, transparent);
  }
  .btn-primary:hover { box-shadow: 0 10px 28px -8px color-mix(in oklab, var(--primary) 70%, transparent); }
  .btn-primary:active { transform: scale(0.985); }
  .btn-primary:disabled { opacity: 0.55; cursor: not-allowed; }

  .btn-ghost {
    background: transparent;
    color: var(--primary);
    border: 0;
    padding: 12px 16px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
  }
  .btn-ghost-muted {
    background: transparent;
    color: var(--muted-foreground);
    border: 0;
    padding: 12px 16px;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
  }

  /* ── Flash banner ────────────────────────────────────────────────── */
  .flash {
    margin: 0 0 16px;
    padding: 14px 16px;
    border-radius: 14px;
    font-size: 14px;
    line-height: 1.4;
    display: flex;
    gap: 12px;
    align-items: flex-start;
  }
  .flash-ok {
    background: color-mix(in oklab, var(--success) 10%, var(--card));
    color: var(--success);
    border: 1px solid color-mix(in oklab, var(--success) 30%, transparent);
  }
  .flash-err {
    background: color-mix(in oklab, var(--destructive) 10%, var(--card));
    color: var(--destructive);
    border: 1px solid color-mix(in oklab, var(--destructive) 30%, transparent);
  }
  .flash-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: currentColor;
    margin-top: 6px;
    flex-shrink: 0;
  }

  /* ── Verify masthead ────────────────────────────────