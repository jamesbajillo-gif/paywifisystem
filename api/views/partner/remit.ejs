<%# GCASH-ONLY-2026-06-03 — partner remit page (GCash only) %>
<header class="mb-6">
  <p class="text-[11px] font-bold uppercase tracking-[0.2em]" style="color:var(--primary)">PAYWIFI · Partner</p>
  <h1 class="text-3xl font-bold tracking-tight"><%= partner.partner_name %> · Remit</h1>
  <p class="text-sm mt-1" style="color: var(--muted-foreground)">
    GCash is the only supported remittance method. Pay via QR — Xendit confirms automatically.
  </p>
</header>

<% if (typeof flash !== 'undefined' && flash) { %>
  <div class="mb-4 rounded-xl px-4 py-3 text-sm border"
    style="background-color: color-mix(in oklab, <%= flash.kind === 'ok' ? 'var(--success)' : 'var(--destructive)' %> 10%, var(--card));
           color: <%= flash.kind === 'ok' ? 'var(--success)' : 'var(--destructive)' %>;
           border-color: color-mix(in oklab, <%= flash.kind === 'ok' ? 'var(--success)' : 'var(--destructive)' %> 35%, transparent);">
    <%= flash.message %>
  </div>
<% } %>

<!-- Balance card -->
<div class="rounded-2xl border-2 p-5 mb-6" style="background: var(--card); border-color: var(--border)">
  <h2 class="text-base font-bold mb-3">Your balance</h2>
  <dl class="space-y-2 text-sm">
    <div class="flex justify-between">
      <dt style="color: var(--muted-foreground)">Total sales (<%= balance.paid_count %> paid)</dt>
      <dd class="font-bold tabular-nums"><%= fmtPHP(balance.gross) %></dd>
    </div>
    <div class="flex justify-between">
      <dt style="color: var(--muted-foreground)">Partner profit (<%= balance.commission_pct.toFixed(0) %>%)</dt>
      <dd class="font-bold tabular-nums" style="color: var(--success)"><%= fmtPHP(balance.commission) %></dd>
    </div>
    <div class="flex justify-between border-t pt-2" style="border-color: var(--border)">
      <dt style="color: var(--muted-foreground)">Required remittance (<%= balance.remit_pct.toFixed(0) %>%)</dt>
      <dd class="font-bold tabular-nums"><%= fmtPHP(balance.owed_before_remit) %></dd>
    </div>
    <div class="flex justify-between">
      <dt style="color: var(--muted-foreground)">Total remitted</dt>
      <dd class="font-bold tabular-nums">− <%= fmtPHP(balance.remitted) %></dd>
    </div>
    <div class="flex justify-between border-t pt-2 text-lg" style="border-color: var(--border)">
      <dt class="font-bold">Outstanding</dt>
      <dd class="font-bold tabular-nums" style="color: <%= balance.outstanding > 0 ? 'var(--destructive)' : 'var(--success)' %>">
        <%= fmtPHP(balance.outstanding) %>
      </dd>
    </div>
  </dl>
</div>

<!-- Submit form -->
<section class="rounded-2xl border-2 p-5 mb-6" style="background: var(--card); border-color: var(--border)">
  <div class="flex items-center gap-2 mb-3">
    <span style="font-size: 24px">📱</span>
    <h2 class="text-base font-bold">Pay via GCash</h2>
  </div>
  <p class="text-xs mb-4" style="color: var(--muted-foreground)">
    Enter the amount you want to remit. We'll generate a unique GCash QR code via Xendit. Scan it with the GCash app and approve. Once Xendit confirms, your balance updates automatically — no admin approval needed.
  </p>
  <form method="POST" action="/partner/remit/qr-create" class="flex flex-col gap-3">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <div>
      <label class="text-xs font-semibold" style="color: var(--muted-foreground)">Amount to remit (₱)</label>
      <input name="amount" type="number" step="0.01" min="1" max="1000000" required
        placeholder="<%= balance.outstanding > 0 ? balance.outstanding.toFixed(2) : '500.00' %>" />
    </div>
    <button type="submit" class="rounded-xl px-4 h-12 text-base font-bold mt-2"
      style="background: var(--primary); color: var(--primary-foreground)">
      Generate GCash QR
    </button>
  </form>
</section>

<!-- History -->
<section class="rounded-2xl border-2 p-5" style="background: var(--card); border-color: var(--border)">
  <h2 class="text-base font-bold mb-3">Recent remittances</h2>
  <% if (!history.length) { %>
    <p class="text-sm text-center py-6" style="color: var(--muted-foreground)">No remittances yet.</p>
  <% } else { %>
    <ul class="flex flex-col divide-y -mx-5" style="border-color: var(--border)">
      <% history.forEach(function(r){
           var stColor = ({pending:'var(--primary)', approved:'var(--success)', cancelled:'var(--muted-foreground)', rejected:'var(--destructive)'})[r.status] || 'var(--muted-foreground)';
      %>
        <li class="px-5 py-3 flex items-center gap-3 min-w-0">
          <div class="flex-1 min-w-0">
            <p class="font-bold tabular-nums"><%= fmtPHP(r.amount) %>
              <% if (r.xendit_payment_id) { %>
                <span class="text-[10px] font-mono font-normal" style="color: var(--muted-foreground)">· xendit <%= r.xendit_payment_id.slice(-8) %></span>
              <% } %>
            </p>
            <p class="text-xs mt-0.5 truncate" style="color: var(--muted-foreground)">
              ref <span class="font-mono"><%= r.reference_no %></span>
              · submitted <%= relTime(r.created_at) %>
              <% if (r.confirmed_at) { %> · confirmed <%= relTime(r.confirmed_at) %><% } %>
            </p>
          </div>
          <span class="text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-lg shrink-0"
            style="background: color-mix(in oklab, <%= stColor %> 10%, var(--card)); color: <%= stColor %>"><%= r.status %></span>
        </li>
      <% }) %>
    </ul>
  <% } %>
</section>
