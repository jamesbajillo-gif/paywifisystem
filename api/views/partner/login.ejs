<%# PAYWIFI-OPERATOR-OTP-2026-06-03 — modern mobile sign-in %>
<link rel="stylesheet" href="/op-auth.css" />

<div class="auth-shell">
  <header class="auth-hero">
    <div class="auth-brand-mark" aria-hidden="true">P</div>
    <h1 class="auth-title"><% if (pendingPurpose) { %>Enter the code<% } else { %>Partner portal<% } %></h1>
    <p class="auth-subtitle">
      <% if (pendingPurpose) { %>We sent a 6-digit code to your mobile. It's good for 5 minutes.
      <% } else { %>Sign in with your mobile or register a new store.<% } %>
    </p>
  </header>

  <main class="auth-card">
    <% if (typeof flash !== 'undefined' && flash) { %>
      <div class="flash <%= flash.kind === 'ok' ? 'flash-ok' : 'flash-err' %>" role="status">
        <span class="flash-dot" aria-hidden="true"></span>
        <span><%= flash.message %></span>
      </div>
    <% } %>

    <% if (pendingPurpose) { %>
      <%- include('login-otp') %>
    <% } else { %>
      <%- include('login-form') %>
    <% } %>

    <p class="help-link">Need help? Contact your PAYWIFI admin.</p>
  </main>
</div>
