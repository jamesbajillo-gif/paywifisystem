<h1 class="text-2xl font-bold mb-1">SMS Module</h1>
<p class="text-sm text-slate-400 mb-6">Configure the Semaphore SMS provider used to deliver Free WiFi voucher codes to guests.</p>

<!-- ── Semaphore config ──────────────────────────────────────────────────── -->
<div class="bg-slate-800 rounded-lg p-5 mb-6">
  <div class="flex items-start gap-3 mb-4">
    <svg class="mt-0.5 shrink-0" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#60a5fa" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.16 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.07 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21 16z"/></svg>
    <div>
      <h2 class="font-semibold text-slate-100">Semaphore SMS</h2>
      <p class="text-xs text-slate-400 mt-0.5">Used to send Free WiFi vouchers via SMS. Obtain your API key from <span class="text-blue-400">semaphore.co</span>.</p>
    </div>
  </div>

  <% if (locals.flash && flash.length) { %>
    <% flash.forEach(function(f){ %>
      <div class="mb-4 px-4 py-2 rounded text-sm font-medium <%= f.kind === 'ok' ? 'bg-green-900/50 text-green-300' : f.kind === 'warn' ? 'bg-yellow-900/50 text-yellow-300' : 'bg-red-900/50 text-red-300' %>"><%= f.msg %></div>
    <% }); %>
  <% } %>

  <form method="POST" action="/admin/sms">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
      <div>
        <label class="block text-xs text-slate-400 mb-1">API Key</label>
        <input type="text" name="semaphore_api_key" value="<%= semKey %>"
               placeholder="Paste your Semaphore API key"
               class="w-full bg-slate-700 border border-slate-600 rounded px-3 py-2 text-sm text-slate-100 placeholder-slate-500 focus:outline-none focus:border-brand-500" />
      </div>
      <div>
        <label class="block text-xs text-slate-400 mb-1">Sender Name</label>
        <input type="text" name="semaphore_sender_name" value="<%= semSender %>"
               placeholder="PAYWIFI" maxlength="11"
               class="w-full bg-slate-700 border border-slate-600 rounded px-3 py-2 text-sm text-slate-100 placeholder-slate-500 focus:outline-none focus:border-brand-500" />
        <p class="text-xs text-slate-500 mt-1">Max 11 chars. Must be registered with Semaphore.</p>
      </div>
    </div>
    <button type="submit" class="px-4 py-2 rounded bg-brand-600 hover:bg-brand-500 text-white text-sm font-semibold transition-colors">Save Settings</button>
  </form>
</div>

<!-- ── Delivery webhook ──────────────────────────────────────────────────── -->
<div class="bg-slate-800 rounded-lg p-5 mb-6">
  <h2 class="font-semibold text-slate-100 mb-1">Delivery Webhook</h2>
  <p class="text-xs text-slate-400 mb-3">Paste this URL into Semaphore &rsaquo; Settings &rsaquo; Postback URL so delivery status updates automatically.</p>
  <div class="flex items-center gap-2">
    <input type="text" readonly id="webhook-url" value="https://paywifi.net/webhooks/semaphore"
           class="w-full bg-slate-900 border border-slate-700 rounded px-3 py-2 text-sm text-slate-300 font-mono focus:outline-none cursor-text select-all" />
    <button type="button" id="copy-btn"
            onclick="navigator.clipboard.writeText(document.getElementById('webhook-url').value).then(function(){var b=document.getElementById('copy-btn');b.textContent='Copied!';setTimeout(function(){b.textContent='Copy';},2000);})"
            class="px-3 py-2 rounded bg-slate-700 hover:bg-slate-600 text-xs text-slate-300 transition-colors whitespace-nowrap">Copy</button>
  </div>
</div>

<!-- ── How it works ─────────────────────────────────────────────────────── -->
<div class="bg-slate-800 rounded-lg p-5">
  <h2 class="font-semibold text-slate-100 mb-3">How it works</h2>
  <ol class="space-y-2 text-sm text-slate-400 list-decimal list-inside">
    <li>Guest taps <strong class="text-slate-200">Free WiFi</strong> on the captive portal and enters their phone number.</li>
    <li>PAYWIFI generates a voucher and calls the Semaphore API to send it via SMS.</li>
    <li>Semaphore delivers the message and POSTs a delivery report to the webhook URL above.</li>
    <li>The portal polls for the delivery confirmation and shows a <strong class="text-slate-200">Voucher Sent!</strong> screen.</li>
    <li>Guest enters the voucher code on the portal to connect.</li>
  </ol>
</div>
