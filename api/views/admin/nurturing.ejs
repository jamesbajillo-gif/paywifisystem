<%
const stageLabel = {
  registered_direct: 'Registered (direct)',
  trial_claimed:   'Trial Claimed',
  trial_consumed:  'Trial Consumed',
  reg_prompted:    'Reg. Prompted',
  registered:      'Registered',
  signup_rewarded: 'Signup Rewarded',
  welcome_rewarded:'Welcome Rewarded',
  returning:       'Returning'
};
const phaseLabel = {
  new_user:         'Phase 1 — New User Offer',
  trial_end_prompt: 'Phase 2 — Trial-End Prompt',
  signup_reward:    'Phase 3a — Signup Reward',
  welcome_gift:     'Phase 3b — Welcome Gift',
  purchase_near_expiry: 'Paid · Near-Expiry Offer'
};
function fmtTime(ts) {
  if(!ts) return '—';
  return new Date(ts*1000).toLocaleString('en-PH',{timeZone:'Asia/Manila',hour12:true,month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'});
}
%>

<!-- Page Header with Reset All -->
<div class="flex items-center justify-between mb-5">
  <div>
    <h2 class="text-base font-semibold text-slate-100">Pipelines</h2>
    <p class="text-xs text-slate-400 mt-0.5">Nurture campaign config &amp; lead tracking</p>
  </div>
  <form method="POST" action="/admin/nurturing/reset-all"
    onsubmit="return confirm('RESET ALL FOR NEW NURTURE?\n\nThis will:\n• Kick ALL active sessions\n• Clear remembered devices\n• Delete all lead records\n• Clear the voucher queue\n\nDevices will have to re-enter the portal. Continue?')">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <button class="flex items-center gap-1.5 px-4 py-2 rounded-lg bg-red-700 hover:bg-red-600 text-white text-xs font-bold shadow transition">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
      </svg>
      Reset All for New Nurture
    </button>
  </form>
</div>

<!-- Funnel Summary -->
<div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
  <% const stageOrder=['trial_claimed','trial_consumed','reg_prompted','registered','signup_rewarded','welcome_rewarded']; %>
  <% const stageMap={}; byStage.forEach(s=>stageMap[s.stage]=s.n); %>
  <div class="bg-slate-800 rounded-lg p-3 text-center">
    <div class="text-2xl font-bold text-brand-400"><%= total %></div>
    <div class="text-xs text-slate-400 mt-0.5">Total Leads</div>
  </div>
  <div class="bg-slate-800 rounded-lg p-3 text-center">
    <div class="text-2xl font-bold text-green-400"><%= (stageMap['registered']||0)+(stageMap['signup_rewarded']||0)+(stageMap['welcome_rewarded']||0) %></div>
    <div class="text-xs text-slate-400 mt-0.5">Registered</div>
  </div>
  <div class="bg-slate-800 rounded-lg p-3 text-center">
    <div class="text-2xl font-bold text-amber-400"><%= stageMap['reg_prompted']||0 %></div>
    <div class="text-xs text-slate-400 mt-0.5">Prompted</div>
  </div>
  <div class="bg-slate-800 rounded-lg p-3 text-center">
    <div class="text-2xl font-bold text-purple-400"><%= total>0?Math.round(((stageMap['registered']||0)+(stageMap['signup_rewarded']||0)+(stageMap['welcome_rewarded']||0))/total*100):0 %>%</div>
    <div class="text-xs text-slate-400 mt-0.5">Conversion</div>
  </div>
  <div class="bg-slate-800 rounded-lg p-3 text-center">
    <div class="text-2xl font-bold text-blue-400"><%= paid ? paid.n : 0 %></div>
    <div class="text-xs text-slate-400 mt-0.5">Paid Vouchers</div>
  </div>
  <div class="bg-slate-800 rounded-lg p-3 text-center">
    <div class="text-2xl font-bold text-emerald-400">₱<%= paid ? Number(paid.revenue||0).toFixed(0) : 0 %></div>
    <div class="text-xs text-slate-400 mt-0.5">Revenue</div>
  </div>
  <div class="bg-slate-800 rounded-lg p-3 text-center">
    <div class="text-2xl font-bold text-cyan-400"><%= typeof converted!=='undefined' ? converted : 0 %></div>
    <div class="text-xs text-slate-400 mt-0.5">Trial &#8594; Paid</div>
  </div>
</div>

<!-- Phase Config Cards -->
<% configs.forEach(function(cfg){ %>
<div class="bg-slate-800 rounded-xl p-5 mb-4 border border-slate-700">
  <div class="flex items-center justify-between mb-4">
    <div>
      <h3 class="font-semibold text-slate-100 text-sm"><%= phaseLabel[cfg.phase] || cfg.phase %></h3>
      <p class="text-xs text-slate-400 mt-0.5"><%= cfg.name %></p>
    </div>
    <span class="text-xs px-2 py-0.5 rounded-full <%= cfg.enabled ? 'bg-green-900/50 text-green-400' : 'bg-slate-700 text-slate-400' %>">
      <%= cfg.enabled ? 'Enabled' : 'Disabled' %>
    </span>
  </div>
  <form method="POST" action="/admin/nurturing/phase/<%= cfg.phase %>">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-3">
      <% if(cfg.phase !== 'trial_end_prompt' && cfg.phase !== 'new_user' && cfg.phase !== 'purchase_near_expiry') { %>
      <div>
        <label class="block text-xs text-slate-400 mb-1">Duration (minutes)</label>
        <input type="number" name="duration_minutes" value="<%= cfg.duration_minutes %>" min="0"
          class="w-full bg-slate-900 border border-slate-600 rounded px-3 py-1.5 text-sm text-slate-200 focus:outline-none focus:border-brand-500" />
      </div>
      <div>
        <label class="block text-xs text-slate-400 mb-1">Bandwidth (kbps, 0=unlimited)</label>
        <input type="number" name="bandwidth_kbps" value="<%= cfg.bandwidth_kbps %>" min="0"
          class="w-full bg-slate-900 border border-slate-600 rounded px-3 py-1.5 text-sm text-slate-200 focus:outline-none focus:border-brand-500" />
      </div>
      <% } else { %>
      <input type="hidden" name="duration_minutes" value="0" />
      <input type="hidden" name="bandwidth_kbps" value="0" />
      <% } %>
      <div>
        <label class="block text-xs text-slate-400 mb-1">Alert Title</label>
        <input type="text" name="alert_title" value="<%= cfg.alert_title %>"
          class="w-full bg-slate-900 border border-slate-600 rounded px-3 py-1.5 text-sm text-slate-200 focus:outline-none focus:border-brand-500" />
      </div>
      <div>
        <label class="block text-xs text-slate-400 mb-1">Alert CTA Button Label</label>
        <input type="text" name="alert_cta" value="<%= cfg.alert_cta %>"
          class="w-full bg-slate-900 border border-slate-600 rounded px-3 py-1.5 text-sm text-slate-200 focus:outline-none focus:border-brand-500" />
      </div>
    </div>
    <div class="mb-3">
      <label class="block text-xs text-slate-400 mb-1">Alert Body</label>
      <textarea name="alert_body" rows="2"
        class="w-full bg-slate-900 border border-slate-600 rounded px-3 py-1.5 text-sm text-slate-200 focus:outline-none focus:border-brand-500"><%= cfg.alert_body %></textarea>
    </div>
    <div class="mb-3">
      <label class="block text-xs text-slate-400 mb-1">SMS Template
        <% if(cfg.phase==='trial_end_prompt'||cfg.phase==='purchase_near_expiry'){ %><span class="text-slate-500 font-normal">&nbsp;— vars: {link}</span><% } else if(cfg.phase==='new_user'){ %><span class="text-slate-500 font-normal">&nbsp;— not used (portal promo only)</span><% } else { %><span class="text-slate-500 font-normal">&nbsp;— vars: {code} {duration}</span><% } %>
      </label>
      <textarea name="sms_template" rows="2"
        class="w-full bg-slate-900 border border-slate-600 rounded px-3 py-1.5 text-sm text-slate-200 focus:outline-none focus:border-brand-500"><%= cfg.sms_template %></textarea>
    </div>
    <div class="flex items-center gap-4">
      <label class="flex items-center gap-2 text-xs text-slate-300 cursor-pointer">
        <input type="hidden" name="enabled" value="0" />
        <input type="checkbox" name="enabled" value="1" <%= cfg.enabled ? 'checked' : '' %>
          class="rounded" />
        Phase Enabled
      </label>
      <label class="flex items-center gap-2 text-xs text-slate-300 cursor-pointer">
        <input type="hidden" name="sms_enabled" value="0" />
        <input type="checkbox" name="sms_enabled" value="1" <%= cfg.sms_enabled ? 'checked' : '' %>
          class="rounded" />
        SMS Enabled
      </label>
      <button class="ml-auto px-4 py-1.5 rounded bg-brand-500 hover:bg-brand-600 text-white text-xs font-semibold">Save Phase</button>
    </div>
  </form>
</div>
<% }) %>


<!-- Recent Leads Table -->
<div class="bg-slate-800 rounded-xl p-4 border border-slate-700">
  <div class="flex items-center justify-between mb-3">
    <h3 class="font-semibold text-slate-200 text-sm">Recent Leads (<%= recentLeads.length %>)</h3>
    <form method="POST" action="/admin/nurturing/leads/clear" onsubmit="return confirm('Delete all lead funnel records only? (Sessions stay active)')">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <button class="px-3 py-1 rounded bg-slate-700 hover:bg-slate-600 text-slate-300 text-xs font-semibold">Clear Leads Only</button>
    </form>
  </div>
  <% if(recentLeads.length === 0) { %>
    <p class="text-slate-500 text-sm text-center py-4">No leads yet.</p>
  <% } else { %>
  <div class="overflow-x-auto">
    <table class="w-full text-xs text-slate-300">
      <thead><tr class="border-b border-slate-700">
        <th class="text-left py-1.5 pr-3 text-slate-400 font-medium">Phone</th>
        <th class="text-left py-1.5 pr-3 text-slate-400 font-medium">MAC</th>
        <th class="text-left py-1.5 pr-3 text-slate-400 font-medium">Stage</th>
        <th class="text-left py-1.5 pr-3 text-slate-400 font-medium">Registered</th>
        <th class="text-left py-1.5 text-slate-400 font-medium">Updated</th>
      </tr></thead>
      <tbody>
      <% recentLeads.forEach(function(l){ %>
        <tr class="border-b border-slate-700/50 hover:bg-slate-700/30">
          <td class="py-1.5 pr-3 font-mono"><%= l.phone %></td>
          <td class="py-1.5 pr-3 font-mono text-slate-400"><%= l.mac_address||'—' %></td>
          <td class="py-1.5 pr-3">
            <span class="px-1.5 py-0.5 rounded text-xs
              <%= l.stage==='welcome_rewarded'||l.stage==='signup_rewarded' ? 'bg-green-900/40 text-green-400' :
                  l.stage==='registered' ? 'bg-blue-900/40 text-blue-400' :
                  l.stage==='reg_prompted' ? 'bg-amber-900/40 text-amber-400' :
                  'bg-slate-700 text-slate-400' %>">
              <%= stageLabel[l.stage]||l.stage %>
            </span>
          </td>
          <td class="py-1.5 pr-3 text-slate-400"><%= fmtTime(l.registered_at) %></td>
          <td class="py-1.5 text-slate-400"><%= fmtTime(l.updated_at) %></td>
        </tr>
      <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>
