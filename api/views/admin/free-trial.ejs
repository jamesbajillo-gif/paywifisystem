<h1 class="text-2xl font-bold mb-1">Free Trial Campaigns</h1>
<p class="text-sm text-slate-400 mb-6">Create and manage free trial offers shown to guests on the captive portal.</p>

<!-- Overview stats -->
<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
  <div class="bg-slate-800 rounded-lg p-4 text-center">
    <div class="text-2xl font-bold text-brand-400"><%= overview.today %></div>
    <div class="text-xs text-slate-400 mt-1">Claims today</div>
  </div>
  <div class="bg-slate-800 rounded-lg p-4 text-center">
    <div class="text-2xl font-bold text-slate-200"><%= overview.week %></div>
    <div class="text-xs text-slate-400 mt-1">This week</div>
  </div>
  <div class="bg-slate-800 rounded-lg p-4 text-center">
    <div class="text-2xl font-bold text-slate-200"><%= overview.total %></div>
    <div class="text-xs text-slate-400 mt-1">All-time claims</div>
  </div>
  <div class="bg-slate-800 rounded-lg p-4 text-center">
    <div class="text-2xl font-bold text-slate-200"><%= overview.devices %></div>
    <div class="text-xs text-slate-400 mt-1">Unique devices</div>
  </div>
</div>

<!-- Actions bar -->
<div class="flex items-center justify-between mb-4 gap-4 flex-wrap">
  <h2 class="font-semibold text-slate-200 text-sm">Campaigns (<%= campaigns.length %>)</h2>
  <div class="flex gap-2">
    <form method="POST" action="/admin/free-trial/reset-today" onsubmit="return confirm('Reset all of today\'s claims across all campaigns?')">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <button class="px-3 py-1.5 rounded bg-slate-700 hover:bg-slate-600 text-slate-300 text-xs font-semibold transition-colors">Reset Today</button>
    </form>
    <form method="POST" action="/admin/free-trial/reset-all" onsubmit="return confirm('Delete ALL free trial claims across ALL campaigns and ALL time? This cannot be undone.')">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <button class="px-3 py-1.5 rounded bg-red-900/40 hover:bg-red-900/70 text-red-400 text-xs font-semibold transition-colors">Reset All</button>
    </form>
    <a href="/admin/free-trial/new" class="px-4 py-1.5 rounded bg-brand-500 hover:bg-brand-600 text-white text-xs font-bold transition-colors">+ New Campaign</a>
  </div>
</div>

<!-- Campaign cards -->
<% if (campaigns.length === 0) { %>
  <div class="bg-slate-800 rounded-lg p-10 text-center">
    <svg class="mx-auto mb-3 text-slate-600" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12.55a11 11 0 0 1 14.08 0"/><path d="M1.42 9a16 16 0 0 1 21.16 0"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><circle cx="12" cy="20" r="1"/></svg>
    <p class="text-slate-400 text-sm mb-4">No campaigns yet. Create your first free trial campaign.</p>
    <a href="/admin/free-trial/new" class="inline-block px-5 py-2 rounded bg-brand-500 hover:bg-brand-600 text-white text-sm font-bold">Create Campaign</a>
  </div>
<% } else { %>
  <div class="flex flex-col gap-4">
    <% campaigns.forEach(function(c) { %>
      <div class="bg-slate-800 rounded-lg p-5 border border-slate-700">
        <!-- Header row -->
        <div class="flex items-start justify-between gap-3 mb-3">
          <div class="flex items-center gap-3 min-w-0">
            <span class="text-xs px-2 py-0.5 rounded-full font-bold shrink-0 <%= c.status==='enabled' ? 'bg-green-900/60 text-green-400' : 'bg-slate-700 text-slate-400' %>">
              <%= c.status === 'enabled' ? '● Enabled' : '○ Disabled' %>
            </span>
            <span class="text-xs px-2 py-0.5 rounded-full font-medium shrink-0 <%= c.portal_claimable ? 'bg-blue-900/50 text-blue-300' : 'bg-slate-700 text-slate-400' %>">
              <%= c.portal_claimable ? 'Portal' : 'Auto' %>
            </span>
            <div class="min-w-0">
              <h3 class="font-bold text-slate-100 text-sm truncate"><%= c.name %></h3>
              <% if (c.description) { %><p class="text-xs text-slate-500 truncate"><%= c.description %></p><% } %>
            </div>
          </div>
          <!-- Action buttons -->
          <div class="flex gap-1 shrink-0">
            <a href="/admin/free-trial/<%= c.id %>/edit" class="px-3 py-1.5 rounded bg-slate-700 hover:bg-slate-600 text-slate-300 text-xs font-medium">Edit</a>
            <form method="POST" action="/admin/free-trial/<%= c.id %>">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <input type="hidden" name="_action" value="toggle" />
              <button class="px-3 py-1.5 rounded text-xs font-medium <%= c.status==='enabled' ? 'bg-amber-900/40 text-amber-400 hover:bg-amber-900/60' : 'bg-green-900/40 text-green-400 hover:bg-green-900/60' %>">
                <%= c.status==='enabled' ? 'Disable' : 'Enable' %>
              </button>
            </form>
            <form method="POST" action="/admin/free-trial/<%= c.id %>">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <input type="hidden" name="_action" value="duplicate" />
              <button class="px-3 py-1.5 rounded bg-slate-700 hover:bg-slate-600 text-slate-400 text-xs font-medium">Copy</button>
            </form>
            <form method="POST" action="/admin/free-trial/<%= c.id %>" onsubmit="return confirm('Delete this campaign? This cannot be undone.')">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <input type="hidden" name="_action" value="delete" />
              <button class="px-3 py-1.5 rounded bg-red-900/30 hover:bg-red-900/60 text-red-400 text-xs font-medium">Delete</button>
            </form>
          </div>
        </div>
        <!-- Stats row -->
        <div class="grid grid-cols-5 gap-3 mb-3">
          <div class="bg-slate-900/50 rounded p-2 text-center">
            <div class="text-base font-bold text-brand-400"><%= c.stats.today %></div>
            <div class="text-xs text-slate-500">Today</div>
          </div>
          <div class="bg-slate-900/50 rounded p-2 text-center">
            <div class="text-base font-bold text-slate-300"><%= c.stats.week %></div>
            <div class="text-xs text-slate-500">Week</div>
          </div>
          <div class="bg-slate-900/50 rounded p-2 text-center">
            <div class="text-base font-bold text-slate-300"><%= c.stats.total %></div>
            <div class="text-xs text-slate-500">Total</div>
          </div>
          <div class="bg-slate-900/50 rounded p-2 text-center">
            <div class="text-base font-bold text-slate-300"><%= c.stats.devices %></div>
            <div class="text-xs text-slate-500">Devices</div>
          </div>
          <div class="bg-slate-900/50 rounded p-2 text-center">
            <div class="text-base font-bold text-green-400"><%= c.stats.sms_sent %></div>
            <div class="text-xs text-slate-500">SMS Sent</div>
          </div>
        </div>
        <!-- Config summary -->
        <div class="flex flex-wrap gap-2 text-xs">
          <span class="bg-slate-700 rounded px-2 py-0.5 text-slate-300">⏱ <%= c.duration_minutes %>min</span>
          <span class="bg-slate-700 rounded px-2 py-0.5 text-slate-300">↓<%= c.speed_down_mbps %>/↑<%= c.speed_up_mbps %> Mbps</span>
          <span class="bg-slate-700 rounded px-2 py-0.5 text-slate-300">⌛ Cooldown: <%= c.cooldown_minutes >= 1440 ? Math.round(c.cooldown_minutes/1440)+'d' : c.cooldown_minutes+'min' %></span>
          <span class="bg-slate-700 rounded px-2 py-0.5 text-slate-300">Priority <%= c.priority %></span>
          <% if (c.triggers && c.triggers.length) { c.triggers.forEach(function(t){ %><span class="bg-blue-900/40 text-blue-300 rounded px-2 py-0.5"><%= t %></span><% }); } %>
          <% if (c.sms_enabled) { %><span class="bg-green-900/30 text-green-400 rounded px-2 py-0.5">SMS ✓</span><% } %>
        </div>
      </div>
    <% }); %>
  </div>
<% } %>
