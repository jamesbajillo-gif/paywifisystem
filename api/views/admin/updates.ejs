<%# PAYWIFI-UPDATE-ADMIN-2026-06-02 — admin updates page with GitHub sync card %>
<div class="max-w-5xl mx-auto space-y-6">

  <!-- HEADER -->
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold" style="color: var(--foreground)">Updates</h1>
    <a href="/admin/updates" class="text-sm" style="color: var(--primary)">&#8635; Refresh</a>
  </div>

  <% if (flash) { %>
    <div class="px-4 py-3 rounded-lg border text-sm"
      style="border-color: color-mix(in oklab, <%= flash.kind==='ok' ? 'var(--success)' : 'var(--destructive)' %> 35%, var(--border));
             background:    color-mix(in oklab, <%= flash.kind==='ok' ? 'var(--success)' : 'var(--destructive)' %> 12%, var(--card));
             color:         <%= flash.kind==='ok' ? 'var(--success)' : 'var(--destructive)' %>;">
      <%= flash.message %>
    </div>
  <% } %>

  <!-- GIT SYNC CARD -->
  <%
    var inSync     = git && git.ok && git.behind === 0;
    var statusClr  = !git || !git.ok ? 'var(--destructive)' : (inSync ? 'var(--success)' : 'var(--primary)');
    var statusTxt  = !git || !git.ok ? (git && git.error || 'unknown') : (inSync ? 'up to date' : 'behind ' + git.behind);
    function fmtWhen(ts){ if(!ts) return '—'; return new Date(ts*1000).toLocaleString(); }
  %>
  <div class="rounded-lg border p-5 space-y-4" style="background: var(--card); border-color: var(--border)">
    <div class="flex items-start justify-between gap-4">
      <div>
        <h2 class="text-base font-semibold mb-1" style="color: var(--foreground)">System sync</h2>
        <p class="text-sm" style="color: var(--muted-foreground)">
          Compares the running gateway against
          <a href="https://github.com/jamesbajillo-gif/paywifisystem" target="_blank" class="underline" style="color: var(--primary)">jamesbajillo-gif/paywifisystem</a>
          on the <code><%= (git && git.branch) || 'main' %></code> branch.
        </p>
      </div>
      <span class="px-2 py-1 rounded text-xs font-bold uppercase tracking-wider"
        style="background: color-mix(in oklab, <%= statusClr %> 15%, var(--card)); color: <%= statusClr %>; border: 1px solid color-mix(in oklab, <%= statusClr %> 35%, var(--border))">
        <%= statusTxt %>
      </span>
    </div>

    <% if (git && git.ok) { %>
      <div class="grid grid-cols-2 gap-x-6 gap-y-3 text-sm pt-3 border-t" style="border-color: var(--border)">
        <div>
          <div class="text-xs uppercase tracking-wider mb-1" style="color: var(--muted-foreground)">Installed</div>
          <div class="font-mono text-xs" style="color: var(--foreground)"><%= git.local && git.local.short || '—' %></div>
          <div class="text-xs mt-1" style="color: var(--muted-foreground)"><%= git.local && git.local.msg || '' %></div>
          <div class="text-[10px] mt-1" style="color: var(--muted-foreground)"><%= fmtWhen(git.local && git.local.when) %><% if (git.local && git.local.author) { %> · <%= git.local.author %><% } %></div>
        </div>
        <div>
          <div class="text-xs uppercase tracking-wider mb-1" style="color: var(--muted-foreground)">Latest on GitHub</div>
          <div class="font-mono text-xs" style="color: var(--foreground)"><%= git.remote && git.remote.short || '—' %></div>
          <div class="text-xs mt-1" style="color: var(--muted-foreground)"><%= git.remote && git.remote.msg || '' %></div>
          <div class="text-[10px] mt-1" style="color: var(--muted-foreground)"><%= fmtWhen(git.remote && git.remote.when) %><% if (git.remote && git.remote.author) { %> · <%= git.remote.author %><% } %></div>
        </div>
      </div>

      <% if (git.behind > 0 && git.commits && git.commits.length) { %>
        <div class="pt-3 border-t" style="border-color: var(--border)">
          <div class="text-xs uppercase tracking-wider mb-2" style="color: var(--muted-foreground)">Pending commits (<%= git.behind %>)</div>
          <ul class="space-y-1">
            <% git.commits.forEach(function(c){ %>
              <li class="text-xs flex items-baseline gap-2">
                <span class="font-mono shrink-0" style="color: var(--primary)"><%= c.short %></span>
                <span class="flex-1" style="color: var(--foreground)"><%= c.msg %></span>
                <span class="text-[10px] shrink-0" style="color: var(--muted-foreground)"><%= fmtWhen(c.when) %></span>
              </li>
            <% }) %>
          </ul>
        </div>
      <% } %>
    <% } else if (git && git.stderr) { %>
      <div class="text-xs font-mono p-3 rounded whitespace-pre-wrap"
        style="background: var(--background); color: var(--destructive); border: 1px solid color-mix(in oklab, var(--destructive) 30%, var(--border))">
        <%= git.stderr %>
      </div>
    <% } %>

    <div class="flex items-center gap-3 pt-3 border-t" style="border-color: var(--border)">
      <form method="POST" action="/admin/updates/git/fetch">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <button type="submit" class="px-3 py-1.5 rounded text-xs font-semibold border transition-colors"
          style="border-color: var(--border); color: var(--foreground); background: var(--card)">
          Check for updates
        </button>
      </form>
      <form method="POST" action="/admin/updates/git/deploy"
        onsubmit="return confirm('Pull from GitHub and deploy to the running system?<%= git && git.behind > 0 ? "\\n\\n" + git.behind + " commits will be applied." : "\\n\\nNo new commits — this will re-sync existing files." %>')">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <button type="submit" class="px-4 py-2 rounded font-semibold text-sm"
          style="background: <%= inSync ? 'var(--muted)' : 'var(--primary)' %>; color: <%= inSync ? 'var(--muted-foreground)' : 'var(--primary-foreground)' %>">
          <%= inSync ? 'Re-sync anyway' : 'Pull & deploy' %>
        </button>
      </form>
      <span class="text-xs" style="color: var(--muted-foreground)">
        Last fetched: <%= fmtWhen(git && git.fetched_at) %>
      </span>
    </div>

    <% if (deployLog) { %>
      <details class="pt-3 border-t" style="border-color: var(--border)">
        <summary class="cursor-pointer text-sm font-semibold" style="color: var(--foreground)">Deploy log (last run)</summary>
        <pre class="font-mono text-[11px] whitespace-pre-wrap overflow-x-auto p-3 rounded mt-2"
          style="background: var(--background); color: var(--muted-foreground); border: 1px solid var(--border); max-height: 320px"><%= deployLog %></pre>
      </details>
    <% } %>
  </div>

  <!-- ADD CHANGELOG ENTRY -->
  <div class="rounded-lg border p-5" style="background: var(--card); border-color: var(--border)">
    <h2 class="text-sm font-semibold mb-3" style="color: var(--foreground)">Add changelog entry</h2>
    <form method="POST" action="/admin/updates/add" class="space-y-3">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <div class="flex flex-col sm:flex-row gap-3">
        <input name="title" required maxlength="200" placeholder="Title (e.g. Auto-registration overhaul)"
          class="flex-1 text-sm px-3 py-2 rounded border"
          style="background: var(--background); border-color: var(--border); color: var(--foreground)" />
        <input name="category" maxlength="24" placeholder="category (feature, fix, audit, security)"
          class="sm:w-64 text-sm px-3 py-2 rounded border"
          style="background: var(--background); border-color: var(--border); color: var(--foreground)" />
      </div>
      <textarea name="body" rows="4" placeholder="Details, findings, fixes, changes…"
        class="w-full text-sm px-3 py-2 rounded border"
        style="background: var(--background); border-color: var(--border); color: var(--foreground)"></textarea>
      <div class="text-right">
        <button type="submit" class="px-4 py-2 rounded font-semibold text-sm"
          style="background: var(--primary); color: var(--primary-foreground)">
          Add entry
        </button>
      </div>
    </form>
  </div>

  <!-- CATEGORY FILTER -->
  <% if (cats && cats.length) { %>
    <div class="flex flex-wrap gap-2 text-xs">
      <a href="/admin/updates" class="px-2 py-1 rounded"
        style="background: <%= !filter ? 'var(--primary)' : 'var(--card)' %>; color: <%= !filter ? 'var(--primary-foreground)' : 'var(--muted-foreground)' %>; border: 1px solid var(--border)">All</a>
      <% cats.forEach(function(c) { %>
        <a href="/admin/updates?category=<%= encodeURIComponent(c) %>" class="px-2 py-1 rounded"
          style="background: <%= filter === c ? 'var(--primary)' : 'var(--card)' %>; color: <%= filter === c ? 'var(--primary-foreground)' : 'var(--muted-foreground)' %>; border: 1px solid var(--border)"><%= c %></a>
      <% }) %>
    </div>
  <% } %>

  <!-- ENTRIES -->
  <% if (!rows || rows.length === 0) { %>
    <div class="rounded-lg border p-8 text-center text-sm" style="background: var(--card); border-color: var(--border); color: var(--muted-foreground)">
      No changelog entries yet.
    </div>
  <% } else { %>
    <% rows.forEach(function(r) {
         var d = new Date((r.created_at || 0) * 1000);
         var when = d.toISOString().replace('T',' ').slice(0,16) + ' UTC';
         var clr = ({feature:'var(--success)', fix:'var(--primary)', audit:'var(--muted-foreground)', security:'var(--destructive)', release:'var(--primary)', deploy:'var(--primary)', quarterly:'var(--success)', update:'var(--muted-foreground)'})[r.category] || 'var(--muted-foreground)';
    %>
      <div class="rounded-lg border p-5" style="background: var(--card); border-color: var(--border)">
        <div class="flex items-start justify-between gap-3">
          <div class="flex items-center gap-2 flex-wrap">
            <span class="text-xs px-2 py-0.5 rounded"
              style="background: color-mix(in oklab, <%= clr %> 15%, var(--card)); color: <%= clr %>; border: 1px solid color-mix(in oklab, <%= clr %> 30%, var(--border))"><%= r.category %></span>
            <h3 class="font-semibold" style="color: var(--foreground)"><%= r.title %></h3>
          </div>
          <form method="POST" action="/admin/updates/delete" onsubmit="return confirm('Delete this entry?')">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <input type="hidden" name="id" value="<%= r.id %>" />
            <button type="submit" class="text-xs" style="color: var(--destructive)">Delete</button>
          </form>
        </div>
        <%# LINKIFY-COMMITS-2026-06-02 — clickable SHA links to the GitHub commit page %>
        <% if (r.body) {
             var REPO_URL = 'https://github.com/jamesbajillo-gif/paywifisystem';
             // Escape body for HTML, then linkify SHA-looking tokens after HTML escape
             function escape(s){ return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;'); }
             var escaped = escape(r.body);
             // Linkify "• abcdef0  msg"  and bare 7-40-char hex SHAs
             var bullet = /^(•\s+)([0-9a-f]{7,40})(\s+)/gm;
             escaped = escaped.replace(bullet, function(_, dot, sha, sp){
               return dot + '<a href="' + REPO_URL + '/commit/' + sha + '" target="_blank" rel="noopener" class="font-mono" style="color: var(--primary); text-decoration: underline">' + sha + '</a>' + sp;
             });
             // Also linkify "(commit abcdef0)" style references
             escaped = escaped.replace(/\bcommit ([0-9a-f]{7,40})\b/g, function(_, sha){
               return 'commit <a href="' + REPO_URL + '/commit/' + sha + '" target="_blank" rel="noopener" class="font-mono" style="color: var(--primary); text-decoration: underline">' + sha + '</a>';
             });
             var isLong = r.body.length > 240;
        %>
          <% if (isLong) { %>
            <details class="mt-2" <%= (r.category === 'deploy' || r.category === 'release' || r.category === 'quarterly') ? 'open' : '' %>>
              <summary class="cursor-pointer text-xs font-semibold" style="color: var(--primary)">View details</summary>
              <div class="text-sm mt-2 whitespace-pre-wrap leading-relaxed" style="color: var(--muted-foreground)"><%- escaped %></div>
            </details>
          <% } else { %>
            <div class="text-sm mt-2 whitespace-pre-wrap leading-relaxed" style="color: var(--muted-foreground)"><%- escaped %></div>
          <% } %>
        <% } %>
        <div class="text-xs mt-3" style="color: var(--muted-foreground)"><%= when %> · <%= r.author || 'admin' %></div>
      </div>
    <% }) %>
  <% } %>
</div>
