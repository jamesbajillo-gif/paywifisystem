<div class="max-w-5xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold">Update Logs</h1>
    <a href="/admin/updates" class="text-sm text-brand-400 hover:underline">&#8635; Refresh</a>
  </div>

  <!-- Add entry -->
  <div class="bg-slate-800 border border-slate-700 rounded-lg p-5 mb-6">
    <h2 class="text-sm font-semibold text-slate-300 mb-3">Add update entry</h2>
    <form method="POST" action="/admin/updates/add" class="space-y-3">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <div class="flex flex-col sm:flex-row gap-3">
        <input name="title" required maxlength="200" placeholder="Title (e.g. Auto-registration overhaul)"
               class="flex-1 bg-slate-900 border border-slate-700 rounded px-3 py-2 text-sm text-slate-100 focus:border-brand-500 outline-none" />
        <input name="category" maxlength="24" placeholder="category (e.g. feature, fix, audit)"
               class="sm:w-56 bg-slate-900 border border-slate-700 rounded px-3 py-2 text-sm text-slate-100 focus:border-brand-500 outline-none" />
      </div>
      <textarea name="body" rows="4" placeholder="Details, findings, fixes, changes…"
                class="w-full bg-slate-900 border border-slate-700 rounded px-3 py-2 text-sm text-slate-100 focus:border-brand-500 outline-none"></textarea>
      <div class="text-right">
        <button type="submit" class="bg-brand-600 hover:bg-brand-500 text-white text-sm font-semibold px-4 py-2 rounded">Add entry</button>
      </div>
    </form>
  </div>

  <!-- Category filter -->
  <% if (cats && cats.length) { %>
    <div class="flex flex-wrap gap-2 mb-4 text-xs">
      <a href="/admin/updates" class="px-2 py-1 rounded <%= !filter ? 'bg-brand-600 text-white' : 'bg-slate-800 text-slate-400 hover:text-slate-100' %>">All</a>
      <% cats.forEach(function(c) { %>
        <a href="/admin/updates?category=<%= encodeURIComponent(c) %>"
           class="px-2 py-1 rounded <%= filter === c ? 'bg-brand-600 text-white' : 'bg-slate-800 text-slate-400 hover:text-slate-100' %>"><%= c %></a>
      <% }) %>
    </div>
  <% } %>

  <!-- Entries -->
  <% if (!rows || rows.length === 0) { %>
    <div class="bg-slate-800 border border-slate-700 rounded-lg p-8 text-center text-slate-500">
      No update entries yet.
    </div>
  <% } else { %>
    <% rows.forEach(function(r) {
         var d = new Date((r.created_at || 0) * 1000);
         var when = d.toISOString().replace('T',' ').slice(0,16) + ' UTC';
         var badge = ({feature:'bg-emerald-900 text-emerald-200', fix:'bg-amber-900 text-amber-200', audit:'bg-sky-900 text-sky-200', security:'bg-rose-900 text-rose-200'})[r.category] || 'bg-slate-700 text-slate-200';
    %>
      <div class="bg-slate-800 border border-slate-700 rounded-lg p-5 mb-3">
        <div class="flex items-start justify-between gap-3">
          <div class="flex items-center gap-2 flex-wrap">
            <span class="text-xs px-2 py-0.5 rounded <%= badge %>"><%= r.category %></span>
            <h3 class="font-semibold text-slate-100"><%= r.title %></h3>
          </div>
          <form method="POST" action="/admin/updates/delete" onsubmit="return confirm('Delete this entry?')">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <input type="hidden" name="id" value="<%= r.id %>" />
            <button type="submit" class="text-xs text-rose-400 hover:underline">Delete</button>
          </form>
        </div>
        <% if (r.body) { %>
          <div class="text-sm text-slate-300 mt-2 whitespace-pre-wrap leading-relaxed"><%= r.body %></div>
        <% } %>
        <div class="text-xs text-slate-500 mt-3"><%= when %> · <%= r.author || 'admin' %></div>
      </div>
    <% }) %>
  <% } %>
</div>
