<%# PAYWIFI-MEDIA-2026-06-03 — admin media library %>
<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold" style="color: var(--foreground)">Media library</h1>
      <p class="text-sm" style="color: var(--muted-foreground)">YouTube videos cached locally for the captive portal. No external network needed at playback time.</p>
    </div>
  </div>

  <% if (flash) { %>
    <div class="px-4 py-3 rounded-lg border text-sm"
      style="border-color: color-mix(in oklab, <%= flash.kind==='ok' ? 'var(--success)' : 'var(--destructive)' %> 35%, var(--border));
             background:    color-mix(in oklab, <%= flash.kind==='ok' ? 'var(--success)' : 'var(--destructive)' %> 12%, var(--card));
             color:         <%= flash.kind==='ok' ? 'var(--success)' : 'var(--destructive)' %>;">
      <%= flash.message %>
    </div>
  <% } %>

  <div class="rounded-lg border p-5" style="background: var(--card); border-color: var(--border)">
    <h2 class="text-base font-semibold mb-3" style="color: var(--foreground)">Add a YouTube video</h2>
    <form method="POST" action="/admin/media/add" class="flex flex-col gap-3">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <input name="url" required maxlength="500" placeholder="https://www.youtube.com/watch?v=…"
        class="text-sm px-3 py-2 rounded border font-mono"
        style="background: var(--background); border-color: var(--border); color: var(--foreground)" />
      <input name="tags" maxlength="200" placeholder="Tags, optional (comma-separated)"
        class="text-sm px-3 py-2 rounded border"
        style="background: var(--background); border-color: var(--border); color: var(--foreground)" />
      <button type="submit" class="px-4 py-2 rounded font-semibold text-sm self-start"
        style="background: var(--primary); color: var(--primary-foreground)">
        Queue for ingestion
      </button>
    </form>
    <p class="text-xs mt-3" style="color: var(--muted-foreground)">
      The system downloads via yt-dlp, normalises to 480p MP4 (H.264 + AAC), stores under <code>/opt/paywifi/portal/media</code>, and exposes the file as <code>/media/videos/&lt;video_id&gt;.mp4</code>. Max duration <code>media_max_duration_sec</code> setting (default 30 min). Duplicates rejected by YouTube video id.
    </p>
  </div>

  <div class="flex gap-2 text-xs">
    <% ['','pending','downloading','processed','failed','disabled'].forEach(function(s){ %>
      <a href="/admin/media<%= s ? '?status='+s : '' %>" class="px-2 py-1 rounded"
        style="background: <%= filter === s ? 'var(--primary)' : 'var(--card)' %>; color: <%= filter === s ? 'var(--primary-foreground)' : 'var(--muted-foreground)' %>; border: 1px solid var(--border)"><%= s || 'all' %></a>
    <% }) %>
  </div>

  <% if (!rows.length) { %>
    <div class="rounded-lg border p-8 text-center text-sm" style="background: var(--card); border-color: var(--border); color: var(--muted-foreground)">
      No media yet.
    </div>
  <% } else { %>
    <div class="rounded-lg border" style="background: var(--card); border-color: var(--border)">
      <% rows.forEach(function(r, idx) {
           var stColor = ({ pending:'var(--muted-foreground)', downloading:'var(--primary)', processed:'var(--success)', failed:'var(--destructive)', disabled:'var(--muted-foreground)' })[r.status] || 'var(--muted-foreground)';
      %>
        <div class="px-4 py-3 <%= idx > 0 ? 'border-t' : '' %>" style="border-color: var(--border)">
          <div class="flex items-start gap-3">
            <% if (r.thumbnail_path) { %>
              <img src="<%= r.thumbnail_path %>" alt="" style="width: 96px; height: 56px; object-fit: cover; border-radius: 6px; flex-shrink: 0; border: 1px solid var(--border)" />
            <% } else { %>
              <div style="width: 96px; height: 56px; background: var(--background); border: 1px solid var(--border); border-radius: 6px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 11px; color: var(--muted-foreground)"><%= r.status === 'downloading' ? '⏳' : '—' %></div>
            <% } %>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 flex-wrap">
                <span class="text-xs font-mono font-bold" style="color: var(--primary)">#<%= r.id %></span>
                <span class="text-[10px] font-bold uppercase tracking-wider px-1.5 py-0.5 rounded"
                  style="background: color-mix(in oklab, <%= stColor %> 15%, var(--card)); color: <%= stColor %>; border: 1px solid color-mix(in oklab, <%= stColor %> 30%, var(--border))"><%= r.status %></span>
                <% if (r.visibility) { %>
                  <span class="text-[10px] font-bold uppercase tracking-wider px-1.5 py-0.5 rounded" style="background: color-mix(in oklab, var(--success) 10%, var(--card)); color: var(--success)">visible</span>
                <% } else { %>
                  <span class="text-[10px] font-bold uppercase tracking-wider px-1.5 py-0.5 rounded" style="background: var(--background); color: var(--muted-foreground)">hidden</span>
                <% } %>
              </div>
              <p class="font-semibold mt-1" style="color: var(--foreground)"><%= r.title || r.source_url %></p>
              <p class="text-xs mt-0.5" style="color: var(--muted-foreground)">
                <% if (r.video_id) { %><span class="font-mono">yt:<%= r.video_id %></span> · <% } %>
                <% if (r.duration_sec) { %><%= Math.floor(r.duration_sec/60) %>:<%= String(r.duration_sec%60).padStart(2,'0') %> · <% } %>
                <% if (r.resolution) { %><%= r.resolution %> · <% } %>
                <% if (r.file_size) { %><%= (r.file_size/1024/1024).toFixed(1) %> MB · <% } %>
                added <%= new Date(r.created_at * 1000).toLocaleString() %>
              </p>
              <% if (r.error) { %>
                <p class="text-xs mt-1" style="color: var(--destructive)">error: <%= r.error %></p>
              <% } %>
            </div>
            <div class="flex flex-col gap-2 shrink-0">
              <% if (r.status === 'processed' && r.file_path) { %>
                <a href="<%= r.file_path %>" target="_blank" class="px-3 py-1 rounded text-[10px] font-bold uppercase tracking-wider"
                  style="background: var(--card); color: var(--primary); border: 1px solid var(--border)">Preview</a>
                <form method="POST" action="/admin/media/<%= r.id %>/visibility">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <input type="hidden" name="value" value="<%= r.visibility ? '0' : '1' %>" />
                  <button type="submit" class="w-full px-3 py-1 rounded text-[10px] font-bold uppercase tracking-wider"
                    style="background: var(--card); color: var(--foreground); border: 1px solid var(--border)"><%= r.visibility ? 'Hide' : 'Show' %></button>
                </form>
              <% } %>
              <% if (r.status === 'failed') { %>
                <form method="POST" action="/admin/media/<%= r.id %>/retry">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <button type="submit" class="w-full px-3 py-1 rounded text-[10px] font-bold uppercase tracking-wider"
                    style="background: var(--primary); color: var(--primary-foreground)">Retry</button>
                </form>
              <% } %>
              <form method="POST" action="/admin/media/<%= r.id %>/delete" onsubmit="return confirm('Delete this media asset and its files?')">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button type="submit" class="w-full px-3 py-1 rounded text-[10px] font-bold uppercase tracking-wider"
                  style="background: var(--card); color: var(--destructive); border: 1px solid color-mix(in oklab, var(--destructive) 30%, var(--border))">Delete</button>
              </form>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>
