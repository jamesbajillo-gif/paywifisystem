<%# PAYWIFI-CLOUDFLARED-2026-06-01 — admin Cloudflare tunnel page %>
<div class="space-y-6">

  <!-- HEADER + status pill -->
  <div class="flex items-start justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold mb-1" style="color: var(--foreground)">Cloudflare Tunnel</h1>
      <p class="text-sm" style="color: var(--muted-foreground)">
        DB-backed configuration for the <code>cloudflared</code> service.
        Saving this page rewrites <code>/etc/paywifi/cloudflared.env</code> and reloads systemd.
      </p>
    </div>
    <div class="flex items-center gap-2">
      <% var stateColor = serviceState === 'active' ? 'var(--success)' : 'var(--destructive)'; %>
      <span class="px-2 py-1 rounded text-xs font-bold uppercase tracking-wider"
        style="background: color-mix(in oklab, <%= stateColor %> 15%, var(--card)); color: <%= stateColor %>; border: 1px solid color-mix(in oklab, <%= stateColor %> 35%, var(--border))">
        <%= serviceState %>
      </span>
      <form method="POST" action="/admin/cloudflare/restart" class="inline" onsubmit="return confirm('Restart the cloudflared service?')">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <button type="submit" class="px-3 py-1.5 rounded text-xs font-semibold border transition-colors"
          style="border-color: var(--border); color: var(--foreground); background: var(--card)">
          Restart service
        </button>
      </form>
    </div>
  </div>

  <% if (flash) { %>
    <div class="px-4 py-3 rounded-lg border text-sm"
      style="border-color: color-mix(in oklab, <%= flash.kind==='ok' ? 'var(--success)' : 'var(--destructive)' %> 35%, var(--border));
             background:    color-mix(in oklab, <%= flash.kind==='ok' ? 'var(--success)' : 'var(--destructive)' %> 12%, var(--card));
             color:         <%= flash.kind==='ok' ? 'var(--success)' : 'var(--destructive)' %>;">
      <%= flash.message %>
    </div>
  <% } %>

  <!-- TUNNEL META + EDIT FORM -->
  <div class="rounded-lg border p-5 space-y-4" style="background: var(--card); border-color: var(--border)">
    <h2 class="text-base font-semibold" style="color: var(--foreground)">Tunnel configuration</h2>

    <% if (cf.hasToken) { %>
      <div class="grid grid-cols-2 gap-x-6 gap-y-3 text-sm">
        <div>
          <div class="text-xs uppercase tracking-wider mb-1" style="color: var(--muted-foreground)">Tunnel ID</div>
          <div class="font-mono text-xs" style="color: var(--foreground)"><%= cf.tunnel_id || '—' %></div>
        </div>
        <div>
          <div class="text-xs uppercase tracking-wider mb-1" style="color: var(--muted-foreground)">Account ID</div>
          <div class="font-mono text-xs" style="color: var(--foreground)"><%= cf.account_id || '—' %></div>
        </div>
        <div>
          <div class="text-xs uppercase tracking-wider mb-1" style="color: var(--muted-foreground)">Current token</div>
          <div class="font-mono text-xs" style="color: var(--foreground)">
            <%= cf.tokenMasked || '—' %>
            <span style="color: var(--muted-foreground)">(<%= cf.tokenLength %> chars)</span>
          </div>
        </div>
        <div>
          <div class="text-xs uppercase tracking-wider mb-1" style="color: var(--muted-foreground)">Last applied</div>
          <div class="text-xs" style="color: var(--foreground)">
            <% if (cf.last_applied_at) { %>
              <%= new Date(cf.last_applied_at * 1000).toLocaleString() %>
              <% if (cf.last_applied_by) { %>
                <span style="color: var(--muted-foreground)"> by <%= cf.last_applied_by %></span>
              <% } %>
            <% } else { %>
              —
            <% } %>
          </div>
        </div>
      </div>
    <% } else { %>
      <div class="px-3 py-2 rounded text-xs"
        style="background: color-mix(in oklab, var(--destructive) 10%, var(--card)); color: var(--destructive); border: 1px solid color-mix(in oklab, var(--destructive) 30%, var(--border))">
        No token configured. Paste your Cloudflare tunnel token below to bring the tunnel up.
      </div>
    <% } %>

    <form method="POST" action="/admin/cloudflare/save" class="space-y-4 pt-2 border-t" style="border-color: var(--border)">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

      <div>
        <label class="block text-xs uppercase tracking-wider mb-1" style="color: var(--muted-foreground)">
          Replace token
          <span style="color: var(--muted-foreground); text-transform: none; font-weight: normal">
            (leave blank to keep current)
          </span>
        </label>
        <textarea name="token" rows="3"
          placeholder="Paste new Cloudflare tunnel token (eyJh…)"
          class="w-full font-mono text-xs px-3 py-2 rounded border"
          style="background: var(--background); border-color: var(--border); color: var(--foreground)"></textarea>
        <p class="text-xs mt-1" style="color: var(--muted-foreground)">
          Generate this in the Cloudflare Zero Trust dashboard: Networks → Tunnels → your tunnel → Configure → "Install and run a connector" → token field.
        </p>
      </div>

      <div>
        <label class="block text-xs uppercase tracking-wider mb-1" style="color: var(--muted-foreground)">Public hostname</label>
        <input type="text" name="hostname" value="<%= cf.hostname %>"
          class="w-full text-sm px-3 py-2 rounded border"
          style="background: var(--background); border-color: var(--border); color: var(--foreground)" />
        <p class="text-xs mt-1" style="color: var(--muted-foreground)">
          Informational only — hostname-to-service mapping lives in the Cloudflare Zero Trust dashboard, not on this gateway.
        </p>
      </div>

      <div class="flex items-center gap-2">
        <input type="checkbox" name="autoupdate" id="cf-autoupdate" value="1" <%= cf.autoupdate ? 'checked' : '' %>
          style="accent-color: var(--primary)" />
        <label for="cf-autoupdate" class="text-sm" style="color: var(--foreground)">
          Auto-update cloudflared (enables the <code>cloudflared-update.timer</code>)
        </label>
      </div>

      <div class="flex items-center gap-2 pt-2">
        <button type="submit" class="px-4 py-2 rounded font-semibold text-sm"
          style="background: var(--primary); color: var(--primary-foreground)">
          Save &amp; apply
        </button>
        <span class="text-xs" style="color: var(--muted-foreground)">
          Writes the DB row, regenerates <code>/etc/paywifi/cloudflared.env</code>, runs <code>systemctl daemon-reload</code>, then restarts the service.
        </span>
      </div>
    </form>
  </div>

  <!-- ENABLE / DISABLE TOGGLE -->
  <div class="rounded-lg border p-5" style="background: var(--card); border-color: var(--border)">
    <h2 class="text-base font-semibold mb-2" style="color: var(--foreground)">Service control</h2>
    <p class="text-sm mb-4" style="color: var(--muted-foreground)">
      Disable to stop the tunnel without erasing the token. The configuration stays in the database; re-enabling brings it back up.
    </p>
    <form method="POST" action="/admin/cloudflare/toggle"
      onsubmit="return confirm('<%= cf.enabled ? "Stop" : "Start" %> the cloudflared service?')">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <input type="hidden" name="enable" value="<%= cf.enabled ? '0' : '1' %>" />
      <% var btnColor = cf.enabled ? 'var(--destructive)' : 'var(--success)'; %>
      <button type="submit" class="px-4 py-2 rounded font-semibold text-sm border"
        style="background: <%= btnColor %>; color: white; border-color: <%= btnColor %>">
        <%= cf.enabled ? 'Disable tunnel' : 'Enable tunnel' %>
      </button>
      <span class="ml-3 text-xs" style="color: var(--muted-foreground)">
        Current DB state: <strong style="color: var(--foreground)"><%= cf.enabled ? 'enabled' : 'disabled' %></strong> · systemd reports: <strong style="color: var(--foreground)"><%= serviceState %></strong>
      </span>
    </form>
  </div>

  <!-- RECENT LOGS -->
  <div class="rounded-lg border p-5" style="background: var(--card); border-color: var(--border)">
    <h2 class="text-base font-semibold mb-2" style="color: var(--foreground)">Recent service log</h2>
    <pre class="font-mono text-xs whitespace-pre-wrap overflow-x-auto p-3 rounded"
      style="background: var(--background); color: var(--muted-foreground); border: 1px solid var(--border); max-height: 320px"><%= journal %></pre>
  </div>

</div>
