<h1 class="text-2xl font-bold mb-6">Settings</h1>

<!-- ── Domain Name ──────────────────────────────────────────────────────────── -->
<%
  var domRow = settings.find(function(s){ return s.key === 'domain_name'; });
  var domVal = domRow ? domRow.value : '';
%>
<div class="mb-6 bg-slate-800 border border-amber-700/40 rounded-lg p-5">
  <div class="flex items-start gap-3 mb-3">
    <span class="text-xl mt-0.5">🌐</span>
    <div>
      <h2 class="font-semibold text-slate-100">Domain Name</h2>
      <p class="text-xs text-slate-400 mt-0.5">Your public-facing URL. Used as the base path for all payment webhook callbacks and return URLs. Must be reachable by Xendit's servers — use your real domain or an ngrok tunnel for testing.</p>
    </div>
  </div>
  <form method="POST" action="/admin/settings" class="space-y-3 text-sm">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <input type="hidden" name="domain_name_only" value="1" />
    <div class="flex gap-2 items-start">
      <div class="flex-1">
        <input id="dn-input" name="domain_name" value="<%= domVal %>"
               placeholder="https://yourdomain.com"
               class="w-full px-3 py-2 rounded bg-slate-900 border border-slate-700 focus:border-amber-500 outline-none text-sm font-mono">
        <p class="text-xs text-slate-500 mt-1">No trailing slash. Include the scheme (https:// or http://).</p>
      </div>
      <button class="shrink-0 px-4 py-2 rounded bg-amber-600 hover:bg-amber-500 text-white font-semibold text-sm transition-colors">Save</button>
    </div>
  </form>
  <div class="mt-3 space-y-1 text-xs font-mono">
    <div class="flex items-center gap-1">
      <span class="text-slate-500 w-28 shrink-0">Xendit webhook</span>
      <span id="cb-xendit" class="truncate text-slate-300"></span>
      <button onclick="cpUrl('cb-xendit',this)" class="shrink-0 ml-1 text-slate-500 hover:text-slate-200 transition-colors" title="Copy">&#x2398;</button>
    </div>
    <div class="flex items-center gap-1">
      <span class="text-slate-500 w-28 shrink-0">Portal root</span>
      <span id="cb-portal" class="truncate text-slate-300"></span>
      <button onclick="cpUrl('cb-portal',this)" class="shrink-0 ml-1 text-slate-500 hover:text-slate-200 transition-colors" title="Copy">&#x2398;</button>
    </div>
    <div class="flex items-center gap-1">
      <span class="text-slate-500 w-28 shrink-0">Admin UI</span>
      <span id="cb-admin" class="truncate text-slate-300"></span>
      <button onclick="cpUrl('cb-admin',this)" class="shrink-0 ml-1 text-slate-500 hover:text-slate-200 transition-colors" title="Copy">&#x2398;</button>
    </div>
  </div>
</div>
      </div>
      <label class="relative inline-flex items-center cursor-pointer shrink-0">
        <input type="checkbox" name="free_trial_enabled" value="1" class="sr-only peer" onchange="document.getElementById('ft-form').submit()" <%= ftEnabled==='1' ? 'checked' : '' %> />
        <div class="w-11 h-6 bg-slate-600 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-brand-500"></div>
      </label>
    </div>
  </form>
</div>

<div class="grid md:grid-cols-2 gap-6">
  <!-- ── Left: system settings ── -->
  <div class="bg-slate-800 rounded-lg p-5">
    <h2 class="font-semibold text-slate-100 mb-1">System settings</h2>
    <p class="text-xs text-slate-400 mb-4">These apply to the portal page that guests see. Changes take effect immediately.</p>
    <form method="POST" action="/admin/settings" class="space-y-4 text-sm">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <% var meta = {
        portal_name:              { label: 'Portal name',              hint: 'Shown as the title on the guest portal (e.g. "MY CAFE WIFI")' },
        portal_brand_color:       { label: 'Brand color',              hint: 'Hex color — reserved for future themed layouts (#0ea5e9)' },
        portal_terms_url:         { label: 'Terms URL',                hint: 'Optional link to terms of service shown to guests' },
        voucher_code_length:      { label: 'Voucher code length',      hint: 'Number of characters in generated voucher codes (8 recommended)' },
        voucher_code_format:      { label: 'Code format',              hint: 'alnum_upper = letters + digits, uppercase only' },
        mac_remember_hours:       { label: 'MAC remember (hours)',     hint: 'How long a device can reconnect without re-entering a voucher. Set 0 to disable.' },
        idle_timeout_min:         { label: 'Idle timeout (min)',       hint: 'Kick a session after this many minutes with no traffic. 0 = never.' },
        rl_max_attempts:          { label: 'Payment attempts (max)',   hint: 'Max payment attempts allowed per rate-limit window. Default 3.' },
        rl_window_min:            { label: 'Rate limit window (min)',  hint: 'Rolling window for counting payment attempts. Default 15 min.' },
        rl_gap_sec:               { label: 'Min gap between attempts (sec)', hint: 'Seconds a client must wait between consecutive payment attempts. Default 15.' },
        rl_cancel_cooldown_sec:   { label: 'Cancel cooldown (sec)',    hint: 'Seconds to wait after cancelling a payment before trying again. Default 10.' },
        partner_contact_number:     { label: 'Partner contact number',  hint: 'Shown in the Cash Payment partner-store block' },
        partner_contact_email:      { label: 'Partner contact email',   hint: 'Shown in the Cash Payment partner block (blank = hide)' },
        partner_cta_text:           { label: 'Partner CTA heading',     hint: 'Heading for the partner-store invitation' },
        partner_availability_status:{ label: 'Partner availability',    hint: 'e.g. Coming Soon / Available' },
        partner_rollout_message:    { label: 'Partner rollout message', hint: 'Short description of the partner-store opportunity' }
      }; %>
      <% settings.forEach(function(s){ %>
        <% if (s.key === 'portal_widgets' || s.key === 'domain_name' || s.key === 'free_trial_enabled' || s.key === 'store_partners' || s.key.startsWith('maintenance_')) return; %>
        <% var m = meta[s.key] || { label: s.key, hint: '' }; %>
        <div>
          <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wide mb-0.5"><%= m.label %></label>
          <% if (m.hint) { %><p class="text-xs text-slate-500 mb-1"><%= m.hint %></p><% } %>
          <input name="<%= s.key %>" value="<%= s.value %>"
                 class="w-full px-3 py-2 rounded bg-slate-900 border border-slate-700 code-cell focus:border-brand-500 outline-none text-sm">
        </div>
      <% }) %>
      <button class="w-full py-2 rounded bg-brand-500 hover:bg-brand-400 text-slate-900 font-semibold transition-colors">Save settings</button>
    </form>
  </div>

  <!-- ── Right: password + quick links ── -->
  <div class="space-y-4">
    <div class="bg-slate-800 rounded-lg p-5">
      <h2 class="font-semibold text-slate-100 mb-1">Change admin password</h2>
      <p class="text-xs text-slate-400 mb-4">Update your login credentials. You will remain logged in after saving.</p>
      <form method="POST" action="/admin/password" class="space-y-3 text-sm">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div>
          <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wide mb-1">Current password</label>
          <input name="current" type="password" required
                 class="w-full px-3 py-2 rounded bg-slate-900 border border-slate-700 focus:border-brand-500 outline-none text-sm">
        </div>
        <div>
          <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wide mb-1">New password</label>
          <input name="next" type="password" required minlength="8"
                 class="w-full px-3 py-2 rounded bg-slate-900 border border-slate-700 focus:border-brand-500 outline-none text-sm">
          <p class="text-xs text-slate-500 mt-0.5">Minimum 8 characters.</p>
        </div>
        <div>
          <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wide mb-1">Confirm new password</label>
          <input name="confirm" type="password" required minlength="8"
                 class="w-full px-3 py-2 rounded bg-slate-900 border border-slate-700 focus:border-brand-500 outline-none text-sm">
        </div>
        <button class="w-full py-2 rounded bg-brand-500 hover:bg-brand-400 text-slate-900 font-semibold transition-colors">Change password</button>
      </form>
    </div>

    <div class="bg-slate-800 rounded-lg p-5">
      <h2 class="font-semibold text-slate-100 mb-2">Quick links</h2>
      <p class="text-xs text-slate-400 mb-3">Jump to related admin sections.</p>
      <div class="space-y-2 text-sm">
        <a href="/admin/plans" class="flex items-center gap-2 text-brand-400 hover:text-brand-300 transition-colors">&#x2192; Manage plans</a>
        <a href="/admin/vouchers/new" class="flex items-center gap-2 text-brand-400 hover:text-brand-300 transition-colors">&#x2192; Generate voucher batch</a>
        <a href="/admin/reports" class="flex items-center gap-2 text-brand-400 hover:text-brand-300 transition-colors">&#x2192; View usage reports</a>
        <a href="/admin/audit" class="flex items-center gap-2 text-brand-400 hover:text-brand-300 transition-colors">&#x2192; View audit log</a>
        <a href="/admin/maintenance" class="flex items-center gap-2 text-brand-400 hover:text-brand-300 transition-colors">&#x2192; Maintenance mode</a>
        <a href="/admin/widgets" class="flex items-center gap-2 text-brand-400 hover:text-brand-300 transition-colors">&#x2192; Portal widgets</a>
      </div>
    </div>
  </div>
</div>

<!-- ── Store Partners (Cash Payment) ────────────────────────────────────── -->
<div class="mt-6 bg-slate-800 rounded-lg p-5">
  <div class="flex items-start gap-3 mb-3">
    <span class="text-xl mt-0.5">🏪</span>
    <div>
      <h2 class="font-semibold text-slate-100">Cash Payment — Store Partners</h2>
      <p class="text-xs text-slate-400 mt-0.5">Where guests can go to pay cash for a WiFi voucher. Shown as a dropdown in the payment wizard when Cash is selected. One entry per line — format: <span class="font-mono bg-slate-700 px-1 rounded text-xs">Store Name | Address</span> or just <span class="font-mono bg-slate-700 px-1 rounded text-xs">Store Name</span>.</p>
    </div>
  </div>
  <form method="POST" action="/admin/settings/store-partners" class="space-y-3 text-sm">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <textarea name="store_partners" rows="5"
              placeholder="SM City Store | Ground Floor, SM City&#10;7-Eleven Branch | Corner Rizal Ave"
              class="w-full px-3 py-2 rounded bg-slate-900 border border-slate-700 focus:border-brand-500 outline-none text-sm font-mono resize-y"
    ><%= storePartnersDisplay %></textarea>
    <button class="px-5 py-2 rounded bg-brand-500 hover:bg-brand-400 text-slate-900 font-semibold transition-colors text-sm">Save stores</button>
  </form>
</div>

<script>
var dni = document.getElementById('dn-input');
function updPrev() {
  var base = (dni && dni.value || '').trim().replace(/\/$/, '');
  var fb = 'https://yourdomain.com';
  document.getElementById('cb-xendit').textContent = (base || fb) + '/api/webhooks/xendit';
  document.getElementById('cb-portal').textContent = (base || fb) + '/';
  document.getElementById('cb-admin').textContent  = (base || fb) + '/admin';
}
if (dni) { dni.addEventListener('input', updPrev); }
updPrev();
window.cpUrl = function(id, btn) {
  var el = document.getElementById(id);
  if (!el) return;
  if (navigator.clipboard) {
    navigator.clipboard.writeText(el.textContent).then(function() {
      var orig = btn.textContent; btn.textContent = '✓';
      setTimeout(function() { btn.textContent = orig; }, 1500);
    });
  }
};
</script>
