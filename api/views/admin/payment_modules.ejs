<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold">Payment Modules</h1>
    <p class="text-sm text-slate-400 mt-1">Configure payment gateway integrations. Wire each module to a Payment Option to enable live payments.</p>
  </div>
  <a href="/admin/payment-options" class="text-sm text-brand-400 hover:underline flex items-center gap-1">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
    Payment Options →
  </a>
</div>

<div class="space-y-4">
<% modules.forEach(function(mod) {
  var cfg = mod.config || {};
  var isSandbox = (cfg.environment || 'sandbox') === 'sandbox';
%>
  <div class="bg-slate-800 rounded-xl border border-slate-700 overflow-hidden">

    <!-- Module header row -->
    <div class="flex items-center gap-4 px-5 py-4">
      <!-- Icon -->
      <div class="w-10 h-10 rounded-lg bg-slate-700 flex items-center justify-center flex-shrink-0 text-brand-400">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
      </div>
      <!-- Info -->
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2">
          <span class="font-bold text-base"><%= mod.name %></span>
          <span class="text-xs px-1.5 py-0.5 rounded <%= mod.is_active ? 'bg-emerald-900 text-emerald-300' : 'bg-slate-700 text-slate-400' %>">
            <%= mod.is_active ? 'Active' : 'Inactive' %>
          </span>
          <% if (mod.is_active) { %>
            <span class="text-xs px-1.5 py-0.5 rounded <%= isSandbox ? 'bg-amber-900 text-amber-300' : 'bg-sky-900 text-sky-300' %>">
              <%= isSandbox ? 'Sandbox' : 'Live' %>
            </span>
          <% } %>
          <% if (!mod.hasAdapter) { %>
            <span class="text-xs px-1.5 py-0.5 rounded bg-rose-900 text-rose-300">Adapter missing</span>
          <% } %>
        </div>
        <p class="text-sm text-slate-400 mt-0.5 truncate"><%= mod.description %></p>
      </div>
      <!-- Actions -->
      <div class="flex gap-2 flex-shrink-0 items-center">
        <% if (mod.hasAdapter) { %>
        <button onclick="testModule('<%= mod.slug %>')"
          id="test-btn-<%= mod.slug %>"
          class="px-3 py-1.5 rounded bg-slate-700 hover:bg-slate-600 text-sm text-slate-200 flex items-center gap-1.5">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          Test
        </button>
        <% } %>
        <button onclick="toggleConfig('<%= mod.slug %>')"
          class="px-3 py-1.5 rounded bg-slate-700 hover:bg-slate-600 text-sm text-slate-200">
          Configure
        </button>
        <form method="POST" action="/admin/payment-modules/<%= mod.slug %>/toggle" class="inline">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button class="px-3 py-1.5 rounded text-sm
            <%= mod.is_active
              ? 'bg-amber-900 text-amber-300 hover:bg-amber-800'
              : 'bg-emerald-900 text-emerald-300 hover:bg-emerald-800' %>">
            <%= mod.is_active ? 'Disable' : 'Enable' %>
          </button>
        </form>
      </div>
    </div>

    <!-- Test result banner (hidden by default) -->
    <div id="test-result-<%= mod.slug %>"
         class="hidden border-t border-slate-700 px-5 py-3 flex items-center gap-3 text-sm">
      <span id="test-icon-<%= mod.slug %>"></span>
      <span id="test-msg-<%= mod.slug %>" class="flex-1"></span>
      <button onclick="dismissTest('<%= mod.slug %>')"
        class="text-slate-500 hover:text-slate-200 text-lg leading-none">&times;</button>
    </div>

    <!-- Config panel (hidden by default) -->
    <div id="config-<%= mod.slug %>" class="hidden border-t border-slate-700 bg-slate-900 px-5 py-5">
      <form method="POST" action="/admin/payment-modules/<%= mod.slug %>/configure" class="space-y-4 text-sm max-w-2xl">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <% if (mod.slug === 'xendit') { %>
          <!-- Xendit-specific fields -->
          <div class="grid grid-cols-2 gap-4">
            <div class="col-span-2">
              <label class="block text-xs uppercase tracking-wide text-slate-400 mb-1">Environment</label>
              <select name="environment"
                class="w-full px-3 py-2 rounded bg-slate-800 border border-slate-700 focus:border-brand-500 outline-none">
                <option value="sandbox" <%= (cfg.environment||'sandbox')==='sandbox' ? 'selected' : '' %>>Sandbox (testing)</option>
                <option value="live"    <%= cfg.environment==='live' ? 'selected' : '' %>>Live (production)</option>
              </select>
              <p class="text-xs text-slate-500 mt-1">Use Sandbox for testing. Switch to Live only when ready to accept real payments.</p>
            </div>

            <div>
              <label class="block text-xs uppercase tracking-wide text-slate-400 mb-1">Secret Key</label>
              <input name="secret_key" type="password" autocomplete="new-password"
                placeholder="<%= cfg.secret_key ? '••••••••' : 'xnd_development_...' %>"
                value=""
                class="w-full px-3 py-2 rounded bg-slate-800 border border-slate-700 focus:border-brand-500 outline-none font-mono text-xs">
              <p class="text-xs text-slate-500 mt-1">From Xendit Dashboard → Settings → API Keys. Leave blank to keep current.</p>
            </div>

            <div>
              <label class="block text-xs uppercase tracking-wide text-slate-400 mb-1">Public Key</label>
              <input name="public_key" type="text" autocomplete="off"
                value="<%= cfg.public_key || '' %>"
                placeholder="xnd_public_development_..."
                class="w-full px-3 py-2 rounded bg-slate-800 border border-slate-700 focus:border-brand-500 outline-none font-mono text-xs">
            </div>

            <div class="col-span-2">
              <label class="block text-xs uppercase tracking-wide text-slate-400 mb-1">Webhook Token (Callback Token)</label>
              <input name="webhook_token" type="password" autocomplete="new-password"
                placeholder="<%= cfg.webhook_token ? '••••••••' : 'Your Xendit callback verification token' %>"
                value=""
                class="w-full px-3 py-2 rounded bg-slate-800 border border-slate-700 focus:border-brand-500 outline-none font-mono text-xs">
              <p class="text-xs text-slate-500 mt-1">Set in Xendit Dashboard → Webhooks. Used to verify incoming webhook calls. Leave blank to keep current.</p>
            </div>
          </div>

          <!-- Callback URL info box -->
          <div class="bg-slate-800 rounded-lg p-3 border border-slate-700 space-y-1">
            <p class="text-xs font-semibold text-slate-300">Configure this callback URL in your Xendit Dashboard:</p>
            <div class="flex items-center gap-2">
              <code class="text-xs text-brand-400 bg-slate-900 px-2 py-1 rounded flex-1 select-all" id="cb-url-<%= mod.slug %>">
                https://YOUR-DOMAIN/api/webhooks/<%= mod.slug %>
              </code>
              <button type="button" onclick="copyUrl('<%= mod.slug %>')"
                class="text-xs px-2 py-1 rounded bg-slate-700 hover:bg-slate-600 flex-shrink-0">Copy</button>
            </div>
            <p class="text-xs text-slate-500">Replace YOUR-DOMAIN with your actual domain or IP. Xendit → Dashboard → Webhooks → Add URL.</p>
          </div>

          <!-- Status indicators -->
          <div class="flex flex-wrap gap-3 text-xs text-slate-400">
            <span class="flex items-center gap-1">
              <span class="w-2 h-2 rounded-full <%= cfg.secret_key ? 'bg-emerald-400' : 'bg-slate-600' %>"></span>
              Secret key <%= cfg.secret_key ? 'saved' : 'not set' %>
            </span>
            <span class="flex items-center gap-1">
              <span class="w-2 h-2 rounded-full <%= cfg.public_key ? 'bg-emerald-400' : 'bg-slate-600' %>"></span>
              Public key <%= cfg.public_key ? 'saved' : 'not set' %>
            </span>
            <span class="flex items-center gap-1">
              <span class="w-2 h-2 rounded-full <%= cfg.webhook_token ? 'bg-emerald-400' : 'bg-slate-600' %>"></span>
              Webhook token <%= cfg.webhook_token ? 'saved' : 'not set' %>
            </span>
          </div>
        <% } else { %>
          <!-- Generic config for future modules -->
          <p class="text-slate-500 text-sm">No configuration schema defined for this module.</p>
        <% } %>

        <div class="flex gap-2 pt-1">
          <button type="submit"
            class="px-4 py-2 rounded bg-brand-500 hover:bg-brand-400 text-slate-900 font-semibold text-sm">
            Save configuration
          </button>
          <button type="button" onclick="toggleConfig('<%= mod.slug %>')"
            class="px-4 py-2 rounded bg-slate-700 hover:bg-slate-600 text-sm">
            Cancel
          </button>
        </div>
      </form>
    </div>

  </div><!-- /module card -->
<% }) %>
</div><!-- /space-y-4 -->

<!-- Future modules placeholder -->
<div class="mt-8 border border-dashed border-slate-700 rounded-xl p-6 text-center">
  <div class="text-slate-500 text-sm">
    <svg class="w-8 h-8 mx-auto mb-2 opacity-30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
    More payment gateways can be added here.<br>
    <span class="text-xs text-slate-600">Each module implements a standard adapter interface — drop in a new <code>src/modules/&lt;slug&gt;.js</code> file and add a row to the <code>payment_modules</code> table.</span>
  </div>
</div>

<script>
function toggleConfig(slug) {
  const el = document.getElementById('config-' + slug);
  el.classList.toggle('hidden');
}
function copyUrl(slug) {
  const el = document.getElementById('cb-url-' + slug);
  const url = el.textContent.trim();
  navigator.clipboard.writeText(url).catch(() => {
    const ta = document.createElement('textarea');
    ta.value = url; document.body.appendChild(ta);
    ta.select(); document.execCommand('copy'); ta.remove();
  });
  const btn = el.nextElementSibling;
  const orig = btn.textContent;
  btn.textContent = 'Copied!';
  setTimeout(() => { btn.textContent = orig; }, 2000);
}

async function testModule(slug) {
  const btn     = document.getElementById('test-btn-' + slug);
  const banner  = document.getElementById('test-result-' + slug);
  const iconEl  = document.getElementById('test-icon-' + slug);
  const msgEl   = document.getElementById('test-msg-' + slug);

  // Spinner while testing
  const origHTML = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = '<svg class="animate-spin" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg> Testing…';

  banner.classList.remove('hidden', 'bg-emerald-900/40', 'bg-rose-900/40');
  iconEl.innerHTML = '';
  msgEl.textContent = 'Connecting…';
  msgEl.className = 'flex-1 text-slate-400';

  try {
    const csrf = document.querySelector('input[name="_csrf"]')?.value || '';
    const r = await fetch('/admin/payment-modules/' + slug + '/test', {
      headers: { 'X-CSRF-Token': csrf, 'Accept': 'application/json' }
    });
    const data = await r.json();

    if (data.ok) {
      banner.classList.add('bg-emerald-900/40');
      iconEl.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#34d399" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
      msgEl.textContent = data.message || 'Connection successful.';
      msgEl.className = 'flex-1 text-emerald-300';
    } else {
      banner.classList.add('bg-rose-900/40');
      iconEl.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f87171" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>';
      msgEl.textContent = data.message || 'Test failed.';
      msgEl.className = 'flex-1 text-rose-300';
    }
  } catch (e) {
    banner.classList.add('bg-rose-900/40');
    iconEl.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f87171" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>';
    msgEl.textContent = 'Request failed: ' + e.message;
    msgEl.className = 'flex-1 text-rose-300';
  } finally {
    btn.disabled = false;
    btn.innerHTML = origHTML;
  }
}

function dismissTest(slug) {
  document.getElementById('test-result-' + slug).classList.add('hidden');
}
</script>
