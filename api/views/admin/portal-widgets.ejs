<%
  var pwRow = settings.find(function(s){ return s.key === 'portal_widgets'; });
  var widgetsInitJson = pwRow && pwRow.value ? pwRow.value : 'null';
%>

<h1 class="text-2xl font-bold mb-2">Portal Widgets</h1>
<p class="text-sm text-slate-400 mb-6">Toggle, reorder, and edit every widget shown to guests on the captive portal. Every widget can be edited via the pencil button. Changes are saved to the database and reflected immediately.</p>

<div class="bg-slate-800 rounded-lg p-4 max-w-3xl">
  <div class="flex items-center justify-between mb-1">
    <h2 class="font-semibold">Widget list</h2>
    <span class="text-xs text-slate-500">Drag to reorder. Toggle to show/hide.</span>
  </div>

  <div class="flex items-center justify-between mb-2 mt-3">
    <span class="text-xs text-slate-400">Bulk actions</span>
    <div class="flex gap-2">
      <button id="btn-enable-all"  class="px-3 py-1 rounded bg-emerald-900 text-emerald-200 text-xs font-semibold hover:bg-emerald-800">Enable all</button>
      <button id="btn-disable-all" class="px-3 py-1 rounded bg-slate-700  text-slate-200  text-xs font-semibold hover:bg-slate-600">Disable all</button>
    </div>
  </div>
  <div id="wl" class="space-y-1.5 mb-3 mt-1"></div>

  <div id="wep" class="hidden bg-slate-900 border border-slate-700 rounded-lg p-4 mb-3">
    <p class="text-xs text-slate-400 mb-3" id="wep-title">Editing widget</p>
    <div id="wef"></div>
    <div class="flex gap-2 mt-3">
      <button id="btn-wep-apply"   class="px-4 py-1.5 rounded bg-slate-700 text-slate-200 text-sm font-semibold hover:bg-slate-600">Apply</button>
      <button id="btn-wep-publish" class="px-4 py-1.5 rounded bg-brand-500 text-slate-900 text-sm font-bold hover:bg-brand-400">Apply &amp; Publish</button>
      <button id="btn-wep-cancel"  class="px-4 py-1.5 rounded bg-slate-800 text-slate-300 text-sm hover:bg-slate-700">Cancel</button>
      <button id="btn-wep-delete"  class="ml-auto px-4 py-1.5 rounded bg-rose-900 text-rose-200 text-sm hover:bg-rose-800">Remove widget</button>
    </div>
  </div>

  <div class="flex items-center gap-2 mb-3">
    <select id="awt" class="flex-1 px-3 py-1.5 rounded bg-slate-900 border border-slate-700 text-sm text-slate-300 outline-none">
      <option value="">+ Add widget...</option>
      <option value="text">Text card</option>
      <option value="announcement">Announcement banner</option>
      <option value="hours">Business hours</option>
      <option value="contact">Contact info</option>
      <option value="promo">Promo banner</option>
      <option value="html">Custom HTML</option>
    </select>
    <button id="btn-add-widget" class="px-4 py-1.5 rounded bg-slate-700 text-slate-100 text-sm hover:bg-slate-600 font-medium">Add</button>
  </div>

  <button id="bsw" class="w-full py-2 rounded bg-brand-500 hover:bg-brand-400 text-slate-900 font-semibold text-sm">Save widget settings</button>
  <p id="wss" class="text-xs text-center mt-2 hidden"></p>
</div>

<script>
window.CSRF = '<%= csrfToken %>';
window.MEDIA_ASSETS = <%- JSON.stringify(typeof mediaAssets !== 'undefined' ? mediaAssets : []) %>;
window.MEDIA_STATS  = <%- JSON.stringify(typeof mediaStats  !== 'undefined' ? mediaStats  : {}) %>;
window.PARTNERS     = <%- JSON.stringify(typeof partners    !== 'undefined' ? partners    : []) %>;
window.PW_WIDGETS_INIT = <%- widgetsInitJson %>;
</script>
<script src="/admin-portal-widgets.js"></script>
