[Unit]
Description=cloudflared (managed by PAYWIFI admin UI)
After=network-online.target
Wants=network-online.target

[Service]
TimeoutStartSec=15
Type=notify
EnvironmentFile=/etc/paywifi/cloudflared.env
ExecStart=/usr/bin/cloudflared --no-autoupdate tunnel run --token ${TUNNEL_TOKEN}
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=multi-user.target
