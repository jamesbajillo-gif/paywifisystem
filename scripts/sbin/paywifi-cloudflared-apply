#!/usr/bin/env bash
# PAYWIFI-CLOUDFLARED-APPLY-2026-06-01 — reconcile cloudflared with cf_* settings.
# DB is authoritative. Idempotent.
set -euo pipefail

DB=/var/lib/paywifi/paywifi.db
ENVF=/etc/paywifi/cloudflared.env
UNIT=/etc/systemd/system/cloudflared.service

get() { sqlite3 "$DB" "SELECT value FROM settings WHERE key='$1';"; }

TOKEN=$(get cf_tunnel_token)
ENABLED=$(get cf_enabled)
AUTOUPD=$(get cf_autoupdate_enabled)

if [ -z "$TOKEN" ]; then
  echo "no cf_tunnel_token in DB" >&2
  exit 2
fi

install -d -m 750 -g paywifi /etc/paywifi 2>/dev/null || { mkdir -p /etc/paywifi; chmod 750 /etc/paywifi; chgrp paywifi /etc/paywifi 2>/dev/null || true; }
umask 077
cat > "$ENVF" <<EOF
# Generated by paywifi-cloudflared-apply — do not edit by hand.
# Edit cf_tunnel_token via /admin/cloudflare instead.
TUNNEL_TOKEN=$TOKEN
EOF
chgrp paywifi "$ENVF" 2>/dev/null || true
chmod 640 "$ENVF"

cat > "$UNIT" <<EOF
[Unit]
Description=cloudflared (managed by PAYWIFI admin UI)
After=network-online.target
Wants=network-online.target

[Service]
TimeoutStartSec=15
Type=notify
EnvironmentFile=$ENVF
ExecStart=/usr/bin/cloudflared --no-autoupdate tunnel run --token \${TUNNEL_TOKEN}
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=multi-user.target
EOF

systemctl daemon-reload

if [ "$ENABLED" = "1" ]; then
  systemctl enable --quiet cloudflared
  systemctl restart cloudflared
else
  systemctl stop cloudflared 2>/dev/null || true
  systemctl disable --quiet cloudflared 2>/dev/null || true
fi

if [ "$AUTOUPD" = "1" ]; then
  systemctl enable --now --quiet cloudflared-update.timer 2>/dev/null || true
else
  systemctl disable --now --quiet cloudflared-update.timer 2>/dev/null || true
fi

echo "ok: applied cf_enabled=$ENABLED cf_autoupdate=$AUTOUPD"
