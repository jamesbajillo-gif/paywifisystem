#!/bin/bash
# paywifi-admin-acl — toggle nginx admin ACL between mgmt-only and lan-allowed
# Usage: paywifi-admin-acl mgmt-only | paywifi-admin-acl lan-allowed
set -euo pipefail

MODE="${1:-}"
MGMT_CONF="/etc/paywifi/nginx-admin-mgmt.conf"
LAN_CONF="/etc/paywifi/nginx-admin-lan.conf"
NGINX_SITE="/etc/nginx/sites-available/paywifi"

if [[ "$MODE" == "mgmt-only" ]]; then
    cp "$MGMT_CONF" "$NGINX_SITE"
elif [[ "$MODE" == "lan-allowed" ]]; then
    cp "$LAN_CONF" "$NGINX_SITE"
else
    echo "Usage: paywifi-admin-acl mgmt-only|lan-allowed" >&2
    exit 1
fi

# Reload nginx (nginx validates config internally before applying)
systemctl reload nginx
echo "OK: admin ACL set to ${MODE}"
